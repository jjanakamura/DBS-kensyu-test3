# ====================================================================
# 環境変数のテンプレート
# 使い方：
#   1. このファイルをコピーして「.env.local」という名前にする
#   2. 下の値を実際のパスワード等に書き換える
#   3. 「.env.local」は .gitignore に含まれるのでGitHubには上がりません
# ====================================================================

# 協会本部 管理画面のログインパスワード（必須）
ADMIN_PASSWORD=ここに管理者パスワードを入れる

# Vercel cron 用のシークレット（Vercelで自動実行する場合のみ）
CRON_SECRET=ここにランダムな文字列を入れる
